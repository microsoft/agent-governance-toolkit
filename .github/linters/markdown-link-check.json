{
  "ignorePatterns": [
    { "pattern": "^http://localhost" },
    { "pattern": "^http://127\\.0\\.0\\.1" },
    { "pattern": "^http://0\\.0\\.0\\.0" },
    { "pattern": "example\\.com" },
    { "pattern": "example\\.org" },
    { "pattern": "example\\.net" },
    { "pattern": "npmjs\\.com" },
    { "pattern": "pypi\\.org/project" },
    { "pattern": "nuget\\.org/packages/Microsoft\\.AgentGovernance" },
    { "pattern": "nist\\.gov" },
    { "pattern": "stackoverflow\\.com" },
    { "pattern": "login\\.microsoftonline\\.com" },
    { "pattern": "portal\\.azure\\.com" },
    { "pattern": "github\\.com/.*/compare/" },
    { "pattern": "github\\.com/.*/releases/new" },
    { "pattern": "github\\.com/.*/stargazers" },
    { "pattern": "singapore-mgf-mapping\\.md" },
    { "pattern": "csa-atf-mapping\\.md" },
    { "pattern": "crates\\.io" },
    { "pattern": "^/README\\.md" }
