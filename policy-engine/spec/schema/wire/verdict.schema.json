{
  "$id": "https://agent-control-specification.test/wire/verdict.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Agent Control Specification verdict",
  "description": "Policy output normalized by the Rust core into a Verdict.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "decision"
  ],
  "properties": {
    "decision": {
      "type": "string",
      "enum": [
        "allow",
        "deny",
        "warn",
        "escalate"
      ]
    },
    "reason": {
      "type": [
        "string",
        "null"
      ],
      "pattern": "^(?!runtime_error:).*",
      "description": "Policy supplied reason. The runtime_error prefix is reserved for core failures."
    },
    "message": {
      "type": [
        "string",
        "null"
      ]
    },
    "effects": {
      "type": [
        "array",
        "null"
      ],
      "items": {
        "$ref": "#/$defs/effect"
      },
      "description": "Effects are applied only for allow and warn decisions. Deny and escalate retain them as rejected policy output."
    },
    "result_labels": {
      "type": [
        "array",
        "null"
      ],
      "items": {
        "type": "string"
      },
      "description": "Policy supplied information-flow labels for the data produced at this sink. The core returns them verbatim; the host persists them with the produced data and re-supplies them as snapshot.ifc.source_labels on later evaluations. The core stores and propagates nothing."
    }
  },
  "$defs": {
    "base_path": {
      "type": "string",
      "pattern": "^\\$policy_target(\\.|\\[|$)",
      "description": "JSON path rooted at $policy_target. Other roots are rejected by the core."
    },
    "replace": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "path",
        "value"
      ],
      "properties": {
        "type": {
          "const": "replace"
        },
        "path": {
          "$ref": "#/$defs/base_path"
        },
        "value": true
      }
    },
    "append": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "path",
        "value"
      ],
      "properties": {
        "type": {
          "const": "append"
        },
        "path": {
          "$ref": "#/$defs/base_path"
        },
        "value": true
      }
    },
    "prepend": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "path",
        "value"
      ],
      "properties": {
        "type": {
          "const": "prepend"
        },
        "path": {
          "$ref": "#/$defs/base_path"
        },
        "value": true
      }
    },
    "redact": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "path"
      ],
      "properties": {
        "type": {
          "const": "redact"
        },
        "path": {
          "$ref": "#/$defs/base_path"
        },
        "pattern": {
          "type": "string",
          "description": "Rust regex crate pattern. The core derives character spans from non empty matches."
        },
        "values": {
          "type": "array",
          "description": "Literal strings. The core derives character spans from non empty occurrences.",
          "items": {
            "type": "string"
          }
        },
        "spans": {
          "type": "array",
          "description": "Ordered non overlapping character offsets into the selected string. The core enforces ordering and bounds.",
          "items": {
            "$ref": "#/$defs/redaction_span"
          }
        },
        "replacement": {
          "type": "string",
          "description": "Replacement for pattern and values forms. Defaults to [REDACTED]."
        }
      },
      "oneOf": [
        {
          "required": [
            "pattern"
          ],
          "not": {
            "anyOf": [
              {
                "required": [
                  "values"
                ]
              },
              {
                "required": [
                  "spans"
                ]
              }
            ]
          }
        },
        {
          "required": [
            "values"
          ],
          "not": {
            "anyOf": [
              {
                "required": [
                  "pattern"
                ]
              },
              {
                "required": [
                  "spans"
                ]
              }
            ]
          }
        },
        {
          "required": [
            "spans"
          ],
          "not": {
            "anyOf": [
              {
                "required": [
                  "pattern"
                ]
              },
              {
                "required": [
                  "values"
                ]
              }
            ]
          }
        }
      ]
    },
    "redaction_span": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "start",
        "end",
        "replacement"
      ],
      "properties": {
        "start": {
          "type": "integer",
          "minimum": 0
        },
        "end": {
          "type": "integer",
          "minimum": 0
        },
        "replacement": {
          "type": "string"
        }
      }
    },
    "effect": {
      "oneOf": [
        {
          "$ref": "#/$defs/replace"
        },
        {
          "$ref": "#/$defs/append"
        },
        {
          "$ref": "#/$defs/prepend"
        },
        {
          "$ref": "#/$defs/redact"
        }
      ]
    }
  }
}
