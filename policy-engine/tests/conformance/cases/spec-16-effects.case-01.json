{
  "$schema": "../cases.schema.json",
  "id": "spec-16-effects.case-01",
  "spec_section": "16",
  "title": "redaction spans use character offsets",
  "claimable": true,
  "operation": "evaluate",
  "sdk_support": {
    "rust": "required",
    "python": "required",
    "node": "required",
    "dotnet": "optional"
  },
  "manifest_yaml": "agent_control_specification_version: 0.3.0-alpha\npolicies:\n  p:\n    type: rego\n    query: data.acs.verdict\nintervention_points:\n  input:\n    policy:\n      id: p\n    policy_target: $snap.input\n",
  "intervention_point": "input",
  "snapshot": {
    "input": {
      "text": "🔥SECRET tail"
    }
  },
  "policy_response": {
    "decision": "warn",
    "effects": [
      {
        "type": "redact",
        "path": "$policy_target.text",
        "spans": [
          {
            "start": 1,
            "end": 7,
            "replacement": "[REDACTED]"
          }
        ]
      }
    ]
  },
  "expected": {
    "decision": "warn",
    "transformed_policy_target": {
      "text": "🔥[REDACTED] tail"
    }
  }
}
