{
  "$schema": "../cases.schema.json",
  "id": "spec-16-effects.case-05",
  "spec_section": "16",
  "title": "redaction values derive and merge character spans",
  "claimable": true,
  "operation": "evaluate",
  "sdk_support": {
    "rust": "required",
    "python": "required",
    "node": "required",
    "dotnet": "optional"
  },
  "manifest_yaml": "agent_control_specification_version: 0.3.0-alpha\npolicies:\n  p:\n    type: rego\n    query: data.acs.verdict\nintervention_points:\n  input:\n    policy:\n      id: p\n    policy_target: $snap.input\n",
  "intervention_point": "input",
  "snapshot": {
    "input": {
      "text": "ababa clear secret secret"
    }
  },
  "policy_response": {
    "decision": "allow",
    "effects": [
      {
        "type": "redact",
        "path": "$policy_target.text",
        "values": ["aba", "bab", "secret"],
        "replacement": "[VALUE]"
      }
    ]
  },
  "expected": {
    "decision": "allow",
    "transformed_policy_target": {
      "text": "[VALUE] clear [VALUE] [VALUE]"
    }
  }
}
